#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  printf 'Usage: fanspeed <0-255|percent%%>\n' >&2
  printf 'Example: fanspeed 200\n' >&2
  exit 2
fi

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
if [[ -x "$script_dir/asustorctl" ]]; then
  exec "$script_dir/asustorctl" fan speed "$1"
fi

exec asustorctl fan speed "$1"
